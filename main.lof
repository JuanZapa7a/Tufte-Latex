\contentsline {figure}{\numberline {8.1}{\ignorespaces Proceso de muestreo y reconstrucción de una señal continua}}{87}{figure.8.1}%
\contentsline {figure}{\numberline {8.2}{\ignorespaces Esquema de un circuito S\&H.}}{87}{figure.8.2}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {8.3}{\ignorespaces Efecto de la tasa de caída (\textit {droop}) durante la fase de retención. Este error limita el tiempo máximo que el ADC puede tardar en convertir sin perder precisión.}}{88}{figure.8.3}%
\contentsline {figure}{\numberline {8.4}{\ignorespaces Relación entre el jitter temporal ($\Delta t_a$) y el error de amplitud ($\Delta V$). A mayor pendiente de la señal, más crítico es el ruido de fase del reloj.}}{88}{figure.8.4}%
\contentsline {figure}{\numberline {8.5}{\ignorespaces Espectro de una señal muestreada. \emph {(a)}~Cuando $f_s > 2f_{max}$ las réplicas espectrales (triángulos azules) quedan separadas y la señal original es recuperable con un filtro paso bajo. \emph {(b)}~Cuando $f_s < 2f_{max}$ las réplicas se solapan (zona roja): la información de alta frecuencia contamina la banda base de forma irreversible.}}{89}{figure.8.5}%
\contentsline {figure}{\numberline {8.6}{\ignorespaces Impacto de la tasa de muestreo en la reconstrucción de una señal de $0{,}9\,\text {Hz}$ (Tasa de Nyquist $= 1{,}8\,\text {Hz}$). \emph {(a)}~Muestreo a $f_s = 4\,\text {Hz}$: se cumple el criterio de Nyquist; la reconstrucción (azul) coincide exactamente con la señal original (gris). \emph {(b)}~Muestreo a $f_s = 1{,}4\,\text {Hz}$: al submuestrear, las muestras (rojas) resultan compatibles con una señal de menor frecuencia ($0{,}5\,\text {Hz}$), induciendo un error de \textit {aliasing} irreversible.}}{89}{figure.8.6}%
\contentsline {figure}{\numberline {8.7}{\ignorespaces Función de transferencia de un ADC.}}{90}{figure.8.7}%
\contentsline {figure}{\numberline {8.8}{\ignorespaces Arquitectura Flash. La señal se compara simultáneamente con todos los niveles de referencia generados por la red divisora.}}{90}{figure.8.8}%
\contentsline {figure}{\numberline {8.9}{\ignorespaces Arquitectura SAR. Un algoritmo de búsqueda binaria ajusta el DAC interno bit a bit hasta aproximarse a la tensión de entrada.}}{90}{figure.8.9}%
\contentsline {figure}{\numberline {8.10}{\ignorespaces Modulador Sigma-Delta. El integrador acumula el error entre la entrada y la estimación, forzando al comparador a generar un tren de pulsos cuya densidad de unos es proporcional a $V_{in}$.}}{91}{figure.8.10}%
\contentsline {figure}{\numberline {8.11}{\ignorespaces ADC de Doble Rampa. El tiempo de descarga es directamente proporcional al voltaje medio de entrada, eliminando ruidos de alta frecuencia.}}{91}{figure.8.11}%
